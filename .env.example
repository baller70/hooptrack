# Runtime (required)
NODE_ENV=development

# Authentication (required; replace locally with at least 32 random characters)
JWT_SECRET=replace-with-a-local-32-character-minimum-secret

# Web Push (required to exercise browser notifications; placeholders only)
VAPID_PUBLIC_KEY=replace-with-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-vapid-private-key
VAPID_SUBJECT=mailto:notifications@example.test
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace-with-the-same-vapid-public-key

# Apple Push Notification service (optional locally; Cloud secrets in staging)
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY_P8=

# Local persistence (optional; defaults are under data/)
HOOPTRACK_DB=data/hooptrack.db
RECORDINGS_DIR=data/recordings
ATTACHMENTS_DIR=data/attachments
NEXT_DIST_DIR=.next

# AI integrations (optional; credentials are configured per trainer in-app)
CODEX_CLI_PATH=
CLAUDE_CLI_PATH=
AI_CLI_TIMEOUT_MS=12000

# Isolated review automation (optional; never use production accounts)
APP_REVIEW_BASE_URL=http://localhost:3000
APP_REVIEW_DEMO_ACCOUNTS_JSON=

# KCLOUD remote checks (Cloud settings only)
KCLOUD_GROUP=KCLOUD-BUILDOUT-20260720
GITHUB_REPOSITORY=baller70/hooptrack
CONTABO_HOST=194.146.12.139
CONTABO_USER=root
CONTABO_SSH_PRIVATE_KEY_B64=
CONTABO_KNOWN_HOSTS=
LOCAL_BRIDGE_PATH=/Volumes/APPLICATIONS/CodexStorage/kcloud-local-bridge/rw-tests
