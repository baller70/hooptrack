# Runtime
NODE_ENV=development
NEXT_DIST_DIR=.next

# Authentication (required; generate locally, never commit a real value)
JWT_SECRET=replace-with-at-least-32-random-bytes

# Web Push (required only when web push is enabled)
VAPID_PUBLIC_KEY=replace-with-public-vapid-key
VAPID_PRIVATE_KEY=replace-with-private-vapid-key
VAPID_SUBJECT=mailto:admin@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=replace-with-the-same-public-vapid-key

# Apple Push Notification service (required only when native APNs is enabled)
APNS_TEAM_ID=replace-with-apple-team-id
APNS_KEY_ID=replace-with-apns-key-id
APNS_PRIVATE_KEY_P8=replace-with-p8-private-key-using-escaped-newlines

# Data and file storage (optional; defaults are defined in lib/constants.ts)
HOOPTRACK_DB=./data/hooptrack.db
RECORDINGS_DIR=./data/recordings
ATTACHMENTS_DIR=./data/attachments

# AI command providers (optional; configure only an approved local provider)
CODEX_CLI_PATH=/absolute/path/to/codex
CLAUDE_CLI_PATH=/absolute/path/to/claude
AI_CLI_TIMEOUT_MS=12000

# App Review screenshot automation (local/CI secret; JSON values must stay out of Git)
APP_REVIEW_DEMO_ACCOUNTS_JSON={}

# KCLOUD setup (Cloud settings/secrets, not application production config)
KCLOUD_GROUP=KCLOUD-BUILDOUT-20260720
GITHUB_REPOSITORY=baller70/hooptrack
CONTABO_HOST=194.146.12.139
CONTABO_USER=root
CONTABO_SSH_PRIVATE_KEY_B64=replace-in-cloud-secrets
CONTABO_SSH_PRIVATE_KEY_FORMAT=base64
CONTABO_KNOWN_HOSTS=replace-in-cloud-secrets-or-generate-during-setup
LOCAL_BRIDGE_PATH=/Volumes/APPLICATIONS/CodexStorage/kcloud-local-bridge/rw-tests
