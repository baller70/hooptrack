{
  "name": "hooptrack",
  "version": "0.1.0",
  "private": true,
  "description": "Basketball tracking application for managing players, sessions, drills, and progress — a Next.js App Router PWA with offline support and web push notifications.",
  "license": "UNLICENSED",
  "author": "HoopTrack",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "audit:knip": "knip",
    "audit:depcheck": "depcheck",
    "audit:madge": "madge --circular --extensions ts,tsx .",
    "audit:licenses": "license-checker --summary",
    "audit:deps": "npm audit --omit=dev",
    "audit:all": "npm run lint && npm run typecheck && npm run audit:knip && npm run audit:depcheck && npm run audit:madge && npm run audit:licenses && npm run audit:deps",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "idb": "^8.0.3",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "next": "^16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@next/bundle-analyzer": "^16.2.10",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "depcheck": "^1.4.7",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "knip": "^6.26.0",
    "license-checker": "^25.0.1",
    "madge": "^8.0.0",
    "playwright": "^1.60.0",
    "size-limit": "^12.1.0",
    "snyk": "^1.1306.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.19"
  }
}
